{
  "widgets": [
    {
      "type": "metric",
      "x": 0,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "metrics": [
          ["AWS/ApplicationELB", "HTTPCode_Target_5XX_Count", "LoadBalancer", "${ALB_ARN_SUFFIX}"]
        ],
        "period": 300,
        "stat": "Sum",
        "region": "us-east-1",
        "title": "ALB 5XX Errors"
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "metrics": [
          ["AWS/ApplicationELB", "UnHealthyHostCount", "TargetGroup", "${TG_ARN_SUFFIX}", "LoadBalancer", "${ALB_ARN_SUFFIX}"]
        ],
        "period": 60,
        "stat": "Average",
        "region": "us-east-1",
        "title": "Unhealthy Hosts"
      }
    }
  ]
}
